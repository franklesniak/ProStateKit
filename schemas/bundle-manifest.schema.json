{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/franklesniak/ProStateKit/schemas/bundle-manifest.schema.json",
  "title": "ProStateKit bundle manifest",
  "description": "Schema for the ProStateKit bundle manifest that records runtime, wrapper, configuration, and validation provenance.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "name",
    "version",
    "schemaVersion",
    "dscVersion",
    "builtAt",
    "sourceCommit",
    "wrapperHash",
    "configHash",
    "runtime",
    "files",
    "validationStatus",
    "supportedPlanes"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "dscVersion": {
      "type": "string",
      "minLength": 1
    },
    "builtAt": {
      "type": "string",
      "minLength": 1
    },
    "sourceCommit": {
      "type": "string",
      "minLength": 1
    },
    "wrapperHash": {
      "type": "string",
      "pattern": "^(TBD|sha256:[a-f0-9]{64})$"
    },
    "configHash": {
      "type": "string",
      "pattern": "^(TBD|sha256:[a-f0-9]{64})$"
    },
    "validationStatus": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "path",
        "expectedHash"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "expectedHash": {
          "type": "string",
          "pattern": "^(TBD|sha256:[a-f0-9]{64})$"
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^(TBD|sha256:[a-f0-9]{64})$"
          }
        }
      }
    },
    "supportedPlanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "Local",
          "Intune",
          "ConfigMgr",
          "CI"
        ]
      }
    }
  }
}
